<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đăng nhập Admin"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:layout_marginBottom="40dp"/>

    <EditText
        android:id="@+id/edtAdminEmailOrId"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Email hoặc ID nhân viên"
        android:paddingHorizontal="16dp"
        android:background="@drawable/bg_search"
        android:layout_marginBottom="16dp"
        android:inputType="textEmailAddress"/>

    <EditText
        android:id="@+id/edtAdminPassword"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Mật khẩu"
        android:paddingHorizontal="16dp"
        android:background="@drawable/bg_search"
        android:layout_marginBottom="24dp"
        android:inputType="textPassword"/>

    <Button
        android:id="@+id/btnAdminLogin"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Đăng nhập"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1B4D2E"
        android:layout_marginBottom="16dp"/>

    <!-- Quên mật khẩu -->
    <TextView
        android:id="@+id/tvForgotAdminPwd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quên mật khẩu?"
        android:textColor="#1B4D2E"
        android:textSize="14sp"
        android:layout_marginBottom="32dp"/>

    <!-- Chuyển sang đăng ký -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chưa có tài khoản? "
            android:textColor="#777"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tvGoToAdminRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng ký ngay"
            android:textColor="#1B4D2E"
            android:textStyle="bold"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

</LinearLayout>