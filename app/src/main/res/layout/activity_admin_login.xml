<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2EC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:background="#F0F2EC">

            <TextView
                android:text="🛡"
                android:textSize="20sp"
                android:textColor="#1B4D2E"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fresh Harvest Admin"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#1B4D2E"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E3DA"/>

        <!-- CARD FORM -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <!-- ICON -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginBottom="20dp">
                    <FrameLayout
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="#EBEBEB"
                        android:backgroundTint="#EBEBEB">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="🔒"
                            android:textSize="32sp"/>
                    </FrameLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="xác thực nhân viên"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_gravity="center"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhập thông tin đăng nhập của bạn để truy cập bảng điều khiển quản lý."
                    android:textSize="14sp"
                    android:textColor="#777"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:layout_marginBottom="28dp"/>

                <!-- EMAIL / STAFF ID -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admin Email or ID Nhân Viên"
                    android:textSize="13sp"
                    android:textColor="#444"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_search"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp"
                    android:layout_marginBottom="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🪪 "
                        android:textSize="16sp"/>
                    <EditText
                        android:id="@+id/edtAdminEmailOrId"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="ID của Bạn or email"
                        android:textSize="14sp"
                        android:inputType="textEmailAddress"/>
                </LinearLayout>

                <!-- PASSWORD -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mật Khẩu"
                        android:textSize="13sp"
                        android:textColor="#444"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvForgotAdminPwd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quên Mật Khẩu?"
                        android:textSize="13sp"
                        android:textColor="#1B4D2E"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_search"
                    android:layout_marginBottom="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="14dp"
                        android:text="🔑 "
                        android:textSize="16sp"/>
                    <EditText
                        android:id="@+id/edtAdminPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="••••••••"
                        android:paddingStart="44dp"
                        android:paddingEnd="48dp"
                        android:inputType="textPassword"/>
                    <ImageView
                        android:id="@+id/btnToggleAdminPwd"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_visibility"
                        android:padding="6dp"
                        android:clickable="true"
                        android:focusable="true"/>
                </RelativeLayout>

                <!-- SECURITY NOTICE -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#EAF4EB"
                    android:padding="14dp"
                    android:gravity="top"
                    android:layout_marginBottom="24dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛡 "
                        android:textSize="15sp"
                        android:textColor="#2E7D32"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Đây là một hệ thống an toàn."
                        android:textSize="12sp"
                        android:textColor="#2E7D32"/>
                </LinearLayout>

                <!-- LOGIN BUTTON -->
                <Button
                    android:id="@+id/btnAdminLogin"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Đăng Nhập →"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#1B4D2E"
                    android:layout_marginBottom="20dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chưa có Tài Khoản? "
                        android:textSize="13sp"
                        android:textColor="#888"/>
                    <TextView
                        android:id="@+id/tvGoToAdminRegister"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đăng Ký"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#1B4D2E"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- FOOTER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingBottom="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="© 2026 Organic Fresh Harvest."
                android:textSize="11sp"
                android:textColor="#999"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>