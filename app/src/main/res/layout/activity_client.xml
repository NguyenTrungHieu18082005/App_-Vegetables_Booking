<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8F3">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/layoutBottomNav"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:text="Fresh Harvest"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#114D18"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <EditText
                android:id="@+id/edtSearch"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_search"
                android:hint="Tìm kiếm thực phẩm..."
                android:paddingHorizontal="16dp" />

            <TextView
                android:text="Sản phẩm nổi bật"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/layoutBottomNav"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_bottom_navigation"
        android:gravity="center"
        android:orientation="horizontal"
        android:weightSum="4">

        <LinearLayout
            android:id="@+id/btnNavHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <LinearLayout android:id="@+id/bgHome" android:layout_width="60dp" android:layout_height="32dp" android:background="@drawable/bg_tab_item_highlight" android:gravity="center">
                <ImageView android:id="@+id/icHome" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_home" />
            </LinearLayout>
            <TextView android:id="@+id/tvHome" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnNavCategories"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <LinearLayout android:id="@+id/bgCategories" android:layout_width="60dp" android:layout_height="32dp" android:background="@drawable/bg_tab_item_highlight" android:gravity="center">
                <ImageView android:id="@+id/icCategories" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_categories" />
            </LinearLayout>
            <TextView android:id="@+id/tvCategories" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Categories" android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnNavOrders"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <LinearLayout android:id="@+id/bgOrders" android:layout_width="60dp" android:layout_height="32dp" android:background="@drawable/bg_tab_item_highlight" android:gravity="center">
                <ImageView android:id="@+id/icOrders" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_orders" />
            </LinearLayout>
            <TextView android:id="@+id/tvOrders" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Orders" android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnNavProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">
            <LinearLayout android:id="@+id/bgProfile" android:layout_width="60dp" android:layout_height="32dp" android:background="@drawable/bg_tab_item_highlight" android:gravity="center">
                <ImageView android:id="@+id/icProfile" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_profile" />
            </LinearLayout>
            <TextView android:id="@+id/tvProfile" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>