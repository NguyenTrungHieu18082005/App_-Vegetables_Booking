<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8F3">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="85dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_menu"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp">

                    <TextView
                        android:text="Fresh Harvest"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#114D18"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="📍 Giao đến: 123 Lê Lợi"
                        android:textSize="14sp"
                        android:textColor="#333"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_search"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_margin="16dp"
                android:background="@drawable/bg_search"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_search"/>

                <EditText
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Tìm kiếm thực phẩm sạch..."
                    android:paddingStart="12dp"/>

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_filter"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginHorizontal="16dp"
                app:cardCornerRadius="20dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/banner"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="24dp"
                        android:orientation="vertical">

                        <TextView
                            android:text="Giảm 20% rau xanh hôm nay"
                            android:textColor="#FFF"
                            android:textStyle="bold"
                            android:textSize="24sp"
                            android:layout_width="250dp"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="Ưu đãi độc quyền cho hội viên Fresh Harvest"
                            android:textColor="#FFF"
                            android:textSize="15sp"
                            android:layout_marginTop="8dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <Button
                            android:layout_width="130dp"
                            android:layout_height="50dp"
                            android:text="Mua ngay"
                            android:textAllCaps="false"
                            android:textSize="18sp"
                            android:textColor="#234000"
                            android:backgroundTint="#B8F55A"
                            android:layout_marginTop="20dp"/>
                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:orientation="horizontal">

                <TextView
                    android:text="Danh mục"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Xem tất cả"
                    android:textColor="#1F5A1B"
                    android:textSize="20sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <Button
                        android:text="🥬 Rau lá"
                        android:textAllCaps="false"
                        android:textColor="#FFF"
                        android:backgroundTint="#0B4B11"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"/>

                    <Button
                        android:text="🥔 Củ quả"
                        android:textAllCaps="false"
                        android:layout_marginStart="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"/>

                    <Button
                        android:text="🌲 Trái cây"
                        android:textAllCaps="false"
                        android:layout_marginStart="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"/>
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:text="Nổi bật"
                android:textSize="30sp"
                android:textStyle="bold"
                android:padding="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/layoutBottomNav"
        android:layout_width="match_parent"
        android:layout_height="85dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_bottom_navigation"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="4">

        <!-- TAB HOME -->
        <LinearLayout
            android:id="@+id/btnNavHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Thay background cứng bằng selector -->
            <LinearLayout
                android:id="@+id/bgHome"
                android:layout_width="65dp"
                android:layout_height="35dp"
                android:background="@drawable/bg_tab_item_highlight"
                android:gravity="center">
                <ImageView
                    android:id="@+id/icHome"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_home"
                   /> <!-- Dùng selector màu -->
            </LinearLayout>
            <TextView
                android:id="@+id/tvHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- TAB CATEGORIES -->
        <LinearLayout
            android:id="@+id/btnNavCategories"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/bgCategories"
                android:layout_width="65dp"
                android:layout_height="35dp"
                android:background="@drawable/bg_tab_item_highlight"
                android:gravity="center">
                <ImageView
                    android:id="@+id/icCategories"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_categories"
                    />
            </LinearLayout>
            <TextView
                android:id="@+id/tvCategories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Categories"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- TAB ORDERS -->
        <LinearLayout
            android:id="@+id/btnNavOrders"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/bgOrders"
                android:layout_width="65dp"
                android:layout_height="35dp"
                android:background="@drawable/bg_tab_item_highlight"
                android:gravity="center">
                <ImageView
                    android:id="@+id/icOrders"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_orders"
                    />
            </LinearLayout>
            <TextView
                android:id="@+id/tvOrders"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Orders"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- TAB PROFILE -->
        <LinearLayout
            android:id="@+id/btnNavProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/bgProfile"
                android:layout_width="65dp"
                android:layout_height="35dp"
                android:background="@drawable/bg_tab_item_highlight"
                android:gravity="center">
                <ImageView
                    android:id="@+id/icProfile"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_profile"
                />
            </LinearLayout>
            <TextView
                android:id="@+id/tvProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

    </LinearLayout>
</RelativeLayout>