<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8F3">

    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#F7F8F3">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_home"
            android:background="@drawable/bg_search"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Địa chỉ nhận hàng"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#114D18"
            android:gravity="center"/>

        <View android:layout_width="36dp" android:layout_height="36dp"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Họ tên người nhận" android:textSize="13sp" android:textColor="#888" android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/edtReceiverName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Nguyễn Văn A"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_search"
                android:layout_marginBottom="16dp"
                android:inputType="textPersonName"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Số điện thoại" android:textSize="13sp" android:textColor="#888" android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/edtReceiverPhone"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="090 123 4567"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_search"
                android:layout_marginBottom="16dp"
                android:inputType="phone"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tỉnh / Thành phố" android:textSize="13sp" android:textColor="#888" android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/edtCity"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="TP. Hồ Chí Minh"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_search"
                android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Quận / Huyện" android:textSize="13sp" android:textColor="#888" android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/edtDistrict"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Quận 1"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_search"
                android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Phường / Xã" android:textSize="13sp" android:textColor="#888" android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/edtWard"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Phường Bến Thành"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_search"
                android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Địa chỉ cụ thể" android:textSize="13sp" android:textColor="#888" android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/edtStreet"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="123 Đường Lê Lợi"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_search"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnSaveAddress"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Lưu địa chỉ"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="#FFF"
                android:backgroundTint="#114D18"
                android:background="@drawable/bg_bottom_navigation"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</RelativeLayout>