<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8F3">

    <!-- HEADER RIÊNG - nằm trên cùng -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#F7F8F3">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/bg_search"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chi tiết sản phẩm"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#114D18"
            android:gravity="center"/>

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_search"
            android:background="@drawable/bg_search"
            android:padding="8dp"/>
    </LinearLayout>

    <!-- BOTTOM BAR -->
    <LinearLayout
        android:id="@+id/layoutBottomBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"
        android:background="#F7F8F3"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_search"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp">

            <TextView
                android:id="@+id/btnMinus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="−"
                android:textSize="20sp"
                android:textColor="#114D18"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/txtQty"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:text="1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <TextView
                android:id="@+id/btnPlus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="+"
                android:textSize="20sp"
                android:textColor="#114D18"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnAddToCart"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="🛒  Thêm vào giỏ hàng"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="#FFF"
            android:backgroundTint="#114D18"
            android:background="@drawable/bg_bottom_navigation"/>
    </LinearLayout>

    <!-- SCROLL CONTENT: nằm giữa header và bottom bar -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutHeader"
        android:layout_above="@id/layoutBottomBar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ẢNH SẢN PHẨM -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="280dp">

                <ImageView
                    android:id="@+id/imgDetail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/tomato"/>

                <TextView
                    android:id="@+id/txtTagDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    android:text="CERTIFIED ORGANIC"
                    android:textColor="#FFF"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:background="@drawable/bg_tag"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- TÊN + GIÁ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/txtDetailName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Dâu tây Đà Lạt (500g)"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#111"/>

                    <TextView
                        android:id="@+id/txtDetailPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="120.000đ"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#2D6B1F"/>
                </LinearLayout>

                <!-- RATING -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☆ 4.8 (120 đánh giá)"
                    android:textSize="14sp"
                    android:textColor="#888"
                    android:layout_marginTop="6dp"/>

                <!-- NGUỒN GỐC + ĐỘ TƯƠI -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:text="📍"
                                android:textSize="18sp"
                                android:gravity="center"
                                android:background="@drawable/bg_active_tab"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:paddingStart="10dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Nguồn gốc"
                                    android:textSize="12sp"
                                    android:textColor="#888"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Việt Nam"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#111"/>
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:text="✅"
                                android:textSize="18sp"
                                android:gravity="center"
                                android:background="@drawable/bg_active_tab"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:paddingStart="10dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Độ tươi"
                                    android:textSize="12sp"
                                    android:textColor="#888"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="100% sạch"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#111"/>
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- MÔ TẢ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mô tả sản phẩm"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111"
                    android:layout_marginTop="20dp"/>

                <TextView
                    android:id="@+id/txtDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dâu tây Đà Lạt được thu hoạch trực tiếp từ các nông trại công nghệ cao tại cao nguyên Lâm Viên. Quả dâu mọng nước, có vị chua nhẹ đặc trưng và hương thơm tự nhiên, không sử dụng chất bảo quản hay thuốc bảo vệ thực vật hóa học."
                    android:textSize="14sp"
                    android:textColor="#555"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginTop="8dp"/>

                <!-- GIÁ TRỊ DINH DƯỠNG -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#F0F7E6"
                    app:cardElevation="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <LinearLayout
                            android:id="@+id/layoutNutrText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toStartOf="@id/layoutTags"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Giá trị dinh dưỡng"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#114D18"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Giàu Vitamin C và chất chống oxy hóa."
                                android:textSize="13sp"
                                android:textColor="#555"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layoutTags"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Vit C"
                                android:textSize="12sp"
                                android:textColor="#114D18"
                                android:textStyle="bold"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="6dp"
                                android:background="@drawable/bg_active_tab"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fiber"
                                android:textSize="12sp"
                                android:textColor="#114D18"
                                android:textStyle="bold"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="6dp"
                                android:layout_marginStart="6dp"
                                android:background="@drawable/bg_active_tab"/>
                        </LinearLayout>
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</RelativeLayout>